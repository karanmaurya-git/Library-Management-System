PORT=4000
JWT_SECRET=change-this-to-a-long-random-string

# Optional: email notifications (reservation-ready, due-soon, overdue reminders).
# If left unset, emails are logged to the backend console instead of sent —
# the app works fully either way, this just enables real delivery.
# Example values for Gmail (use an App Password, not your normal password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   SMTP_FROM=you@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
